{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "UI: lint",
      "type": "npm",
      "script": "lint",
      "path": "ui",
      "group": "build",
      "problemMatcher": "$eslint-stylish",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "UI: format check",
      "type": "npm",
      "script": "format",
      "path": "ui",
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
